  @@index([factoryId])
  @@index([factoryProductionLineId])
  @@index([departmentId])
  @@index([productionOrderId])
  @@index([productionOrderRouteProgressId])
  @@map("shift_line_results")
}

model TutorialProgress {
  id                String           @id @default(cuid())
  factoryId         String           @map("factory_id")
